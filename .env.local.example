# Copy to .env.local and fill in. Server-side only — do NOT prefix with NEXT_PUBLIC_.
DEAL_ENGINE_API_BASE=https://your-backend.replit.dev
DEAL_ENGINE_TOKEN=your-bearer-token

# Supabase auth (public — safe to expose to the browser). Azure/Entra SSO is
# configured in the Supabase dashboard (Auth > Providers > Azure), not here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key
